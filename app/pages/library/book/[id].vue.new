      grid-column: 1;
    }

    :deep(.bdc__header) {
      grid-row: 1;
      grid-column: 2;

      @include respond-below($breakpoint-md) {
        grid-row: auto;
        grid-column: 1;
      }
    }

    :deep(.bdc__title) {
      font-size: $font-size-2xl;
    }

    // Everything below hero spans full width
    :deep(.bdc__description),
    :deep(.bdc__progress),
    :deep(.bdc__rating-row),
    :deep(.bdc__notes-row),
