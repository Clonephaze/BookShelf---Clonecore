# Environment Variables — Bookshelf
# Copy to .env and fill in values.

# --- Database (Neon PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Better Auth ---
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# --- Google Books API (optional, enrichment/fallback) ---
GOOGLE_BOOKS_API_KEY=""

# --- Hardcover API (optional, enrichment) ---
HARDCOVER_API_TOKEN=""

# --- Vercel (set automatically on Vercel, not needed locally) ---
# VERCEL_URL is injected by Vercel at deploy time
